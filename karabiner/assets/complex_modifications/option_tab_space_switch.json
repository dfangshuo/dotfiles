{
  "title": "Option+Tab → Ctrl+Option+Arrow (space switching)",
  "rules": [
    {
      "description": "Option+Tab → Ctrl+Option+Right, Option+Shift+Tab → Ctrl+Option+Left",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "tab",
            "modifiers": {
              "mandatory": ["option", "shift"],
              "optional": ["caps_lock"]
            }
          },
          "to": [
            {
              "key_code": "left_arrow",
              "modifiers": ["left_control", "left_option"]
            }
          ]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "tab",
            "modifiers": {
              "mandatory": ["option"],
              "optional": ["caps_lock"]
            }
          },
          "to": [
            {
              "key_code": "right_arrow",
              "modifiers": ["left_control", "left_option"]
            }
          ]
        }
      ]
    }
  ]
}
